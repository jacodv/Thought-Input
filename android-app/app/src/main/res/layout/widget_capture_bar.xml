<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:background="@drawable/widget_background"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingEnd="8dp">

    <!-- Brain icon — tapping opens capture -->
    <ImageView
        android:id="@+id/widget_icon"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/ic_brain"
        android:contentDescription="@string/app_name" />

    <!-- Hint text — tapping opens capture -->
    <TextView
        android:id="@+id/widget_hint"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="16dp"
        android:text="@string/capture_hint"
        android:textColor="#99FFFFFF"
        android:textSize="16sp"
        android:singleLine="true" />

    <!-- Mic icon — tapping opens capture in voice mode -->
    <ImageView
        android:id="@+id/widget_mic"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:padding="8dp"
        android:src="@drawable/ic_mic"
        android:contentDescription="@string/mic_start"
        android:background="?android:attr/selectableItemBackgroundBorderless" />

</LinearLayout>
