<Window x:Class="ThoughtInput.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thought Input — Settings"
        Width="640" Height="540"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource SurfaceBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Segoe UI Variable, Segoe UI">
    <TabControl Margin="12" Background="{StaticResource SurfaceBrush}" BorderThickness="0">
        <TabItem Header="Destinations">
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Margin="0,0,0,8"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="Where captures are sent. Mark one as active." />

                <ListBox x:Name="DestinationsList"
                         Grid.Row="1"
                         Background="{StaticResource SurfaceMutedBrush}"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         BorderThickness="0"
                         SelectionMode="Single">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="4,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <RadioButton GroupName="ActiveDest"
                                             IsChecked="{Binding IsActive, Mode=TwoWay}"
                                             Checked="OnActiveChanged"
                                             Margin="0,0,8,0"
                                             VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Type, Converter={StaticResource TypeDescriptorConverter}}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="12" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
                    <Button Content="Add" Style="{StaticResource PrimaryButton}" Click="OnAddClick" Margin="0,0,8,0" />
                    <Button Content="Edit" Style="{StaticResource GhostButton}" Click="OnEditClick" Margin="0,0,8,0" />
                    <Button Content="Delete" Style="{StaticResource GhostButton}" Click="OnDeleteClick" Margin="0,0,8,0" />
                    <Button Content="Test" Style="{StaticResource GhostButton}" Click="OnTestClick" />
                </StackPanel>
            </Grid>
        </TabItem>

        <TabItem Header="Import / Export">
            <StackPanel Margin="20">
                <TextBlock Text="Settings backup" FontSize="18" FontWeight="SemiBold" />
                <TextBlock TextWrapping="Wrap" Margin="0,8,0,16"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="Export your destinations and secrets to a JSON file. Compatible with the macOS app." />

                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="Export…" Style="{StaticResource PrimaryButton}" Click="OnExportClick" Margin="0,0,8,0" />
                    <Button Content="Import…" Style="{StaticResource GhostButton}" Click="OnImportClick" />
                </StackPanel>

                <TextBlock x:Name="BackupStatus" Foreground="{StaticResource TextSecondaryBrush}" />

                <TextBlock Margin="0,16,0,0" TextWrapping="Wrap"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="⚠ Exported backups contain secrets in plaintext. Treat them like a password file." />
            </StackPanel>
        </TabItem>

        <TabItem Header="About">
            <StackPanel Margin="20">
                <TextBlock Text="Thought Input" FontSize="22" FontWeight="SemiBold" />
                <TextBlock x:Name="VersionLabel" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0" />
                <TextBlock x:Name="RuntimeLabel" Foreground="{StaticResource TextSecondaryBrush}" />
                <TextBlock Margin="0,16,0,8" FontWeight="SemiBold" Text="Capture shortcut" />
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="HotkeyBox" Width="240" Padding="6" />
                    <Button Content="Apply" Style="{StaticResource PrimaryButton}" Click="OnHotkeyApplyClick" Margin="8,0,0,0" />
                </StackPanel>
                <TextBlock Margin="0,4,0,0" FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="Format: Ctrl+Shift+Space, Ctrl+Alt+T, etc." />
                <CheckBox x:Name="LaunchOnLoginToggle" Content="Launch when I log in" Margin="0,16,0,0"
                          Foreground="{StaticResource TextPrimaryBrush}" Click="OnLaunchToggleClick" />
                <TextBlock Margin="0,16,0,0">
                    <Hyperlink NavigateUri="https://github.com/jacodv/Thought-Input"
                               Foreground="{StaticResource AccentBrush}"
                               RequestNavigate="OnNavigate">
                        github.com/jacodv/Thought-Input
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </TabItem>
    </TabControl>
</Window>
