{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CapturePayload",
  "description": "Payload sent by Thought Input clients when a capture is submitted.",
  "type": "object",
  "required": ["text", "timestamp", "source_platform", "client_version", "capture_method", "idempotency_key", "device_name"],
  "properties": {
    "text": {
      "type": "string",
      "minLength": 1,
      "description": "The captured text content."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when the capture was initiated."
    },
    "source_platform": {
      "type": "string",
      "enum": ["macos", "android"],
      "description": "Platform that originated the capture."
    },
    "client_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the client app."
    },
    "capture_method": {
      "type": "string",
      "enum": ["typed", "voice"],
      "description": "How the text was entered."
    },
    "idempotency_key": {
      "type": "string",
      "format": "uuid",
      "description": "UUID for deduplication on the server side."
    },
    "device_name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable name of the device (e.g. \"Jaco's MacBook Pro\", \"Pixel 9\")."
    }
  },
  "additionalProperties": false
}
